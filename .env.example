# envautomatico - configuración
# Copia este archivo a .env y ajusta los valores.

# Servidor
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Token bearer para proteger los endpoints de generación.
# Generá uno fuerte: `openssl rand -hex 32`
API_TOKEN=cambiame-por-favor

# Rutas (relativas al root del proyecto)
STORAGE_DIR=storage
AUTH_DIR=auth
STORAGE_STATE_FILE=auth/storage_state.json

# URL base pública desde la que se sirven los assets.
# En local: http://localhost:8000
# En VPS:   https://envautomatico.tudominio.com
PUBLIC_BASE_URL=http://localhost:8000

# Playwright
HEADLESS=true
BROWSER_CHANNEL=chromium
NAV_TIMEOUT_MS=60000
GENERATION_TIMEOUT_MS=300000

# Cuenta Envato (solo para el script de login local; el VPS usa storage_state)
ENVATO_LOGIN_URL=https://account.envato.com/sign_in
ENVATO_AI_HOME=https://www.envato.com/ai/
